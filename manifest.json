{
  "manifest_version": 3,
  "name": "Web Element Selector",
  "version": "2.0.0",
  "description": "Visually select page regions, write a task, and copy a Codex-ready prompt.",
  "action": {
    "default_title": "Toggle Web Element Selector",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ]
}
